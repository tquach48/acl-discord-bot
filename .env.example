# ---- Discord ----
# Bot token from the Discord Developer Portal (Bot tab → Reset Token).
DISCORD_TOKEN=
# Application (client) ID from the Developer Portal (General Information).
DISCORD_CLIENT_ID=
# Your Discord server (guild) ID. Enable Developer Mode in Discord, then
# right-click the server → Copy Server ID.
GUILD_ID=

# ---- Supabase (ACL backend) ----
# Project URL, e.g. https://abcd1234.supabase.co
SUPABASE_URL=
# SERVICE-ROLE key (Settings → API). SECRET — full DB access, never commit
# or expose client-side. The bot enforces its own authorization in code.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Channels (right-click channel → Copy Channel ID, Developer Mode on) ----
# Where match reminders / live / final-score posts go.
MATCH_DAY_CHANNEL_ID=
# Where the self-serve "Assign my roles" button message is posted.
ONBOARDING_CHANNEL_ID=

# ---- Optional ----
# Time zone for all user-facing times (default America/Halifax).
TIMEZONE=America/Halifax
# Public site base URL (default https://playacl.ca).
SITE_URL=https://playacl.ca
